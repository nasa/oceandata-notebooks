# use goofys for s3-readonly mounts
USER root
COPY --from=public.ecr.aws/sciencecloud/smce-images:smce-oss-earth-base-9f9fc2c3 /opt/goofys /opt/goofys
RUN /usr/bin/install -o ${NB_USER} -g ${NB_USER} -d /s3-readonly
USER ${NB_USER}

# set location for shared OCSSW data
ARG OCSSWROOT_PUBLIC=/efs/ocssw/

# launch from home
WORKDIR /home/${NB_USER}

# TODO: is this essential?
CMD ["jupyter", "lab", "--no-browser", "--ip", "0.0.0.0"]
